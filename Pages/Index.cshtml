@page
@model IndexModel

<h1 class="text-left my-4">Canciones</h1>

<div class="container">
    <div class="row">

        <!-- Foraeach del model products para que se muestren todos los articulos-->

        @foreach (var product in Model.Products)
        {
            <div class="col-md-4 col-lg-3 mb-4">

                <div class="card h-100 shadow-md">

                    <img src="@product.image" class="card-img-top" style="height:200px; object-fit:cover;" />


                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">@product.name</h5>
                        <p class="card-text fs-4 fw-bold text-success">
                            $@product.price
                        </p>
                        <!--link/boton con la ref de mercadoPago-->
                        <a href="@product.InitPoint" class="btn btn-primary buyBtn" data-id="@product.id" target="_blank"
                           rel="noopener noreferrer">Comprar</a>

                       
                    </div>
                </div>
            </div>
        }

    </div>
</div>
